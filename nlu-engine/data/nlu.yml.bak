version: "3.1"

nlu:
  - intent: greet
    examples: |
      - xin chào
      - hi ad
      - chào chatbot
      - hello
      - xin chao
      - chào ad

  - intent: hoi_thong_tin_nganh
    examples: |
      - Ngành [Khoa học máy tính](nganh_hoc) học những gì?
      - Tư vấn giúp mình ngành [Công nghệ thông tin](nganh_hoc)
      - Ra trường làm gì nếu học [Kỹ thuật phần mềm](nganh_hoc)
      - Thông tin tuyển sinh ngành [An toàn thông tin](nganh_hoc)
      - Ngành [CN1](nganh_hoc) học cái gì thế ad
      - Ngành [CN2](nganh_hoc) có tốt không
      - Cho mình xem thông tin ngành [CN4](nganh_hoc)
      - Điểm chuẩn ngành [CN11](nganh_hoc) là bao nhiêu

  - intent: hoi_hoc_phi
    examples: |
      - Học phí ngành [CNTT](nganh_hoc) là bao nhiêu?
      - Trường mình một năm đóng bao nhiêu tiền học phí?
      - Học phí [Khoa học máy tính](nganh_hoc) có đắt không?
      - học phí bao nhiêu
      - đóng bao nhiêu tiền
      - học phí uet thế nào

  - intent: dang_ky_nguyen_vong
    examples: |
      - Tôi muốn đăng ký nguyện vọng vào trường
      - Cho em đặt nguyện vọng với ad
      - Đăng ký tư vấn xét tuyển ở đâu ạ
      - /dang_ky_nguyen_vong
      - dang_ky_nguyen_vong
      - em muốn nộp hồ sơ xét tuyển
      - đăng ký xét tuyển trực tuyến

  - intent: chon_ptxt_hsa
    examples: |
      - Em muốn xét bằng điểm Đánh giá năng lực
      - Xét tuyển bằng phương thức HSA
      - /chon_ptxt_hsa
      - chon_ptxt_hsa
      - Xét điểm HSA
      - đánh giá năng lực ĐHQGHN

  - intent: chon_ptxt_ielts
    examples: |
      - Xét tuyển kết hợp chứng chỉ tiếng Anh quốc tế
      - Em có bằng IELTS muốn xét tuyển
      - /chon_ptxt_ielts
      - chon_ptxt_ielts
      - xét tuyển ielts kết hợp

  - intent: chon_ptxt_tuyen_thang
    examples: |
      - Diện tuyển thẳng giải quốc gia
      - Đăng ký tuyển thẳng
      - /chon_ptxt_tuyen_thang
      - chon_ptxt_tuyen_thang
      - diện tuyển thẳng học sinh giỏi

  - intent: chon_ptxt_thptqg
    examples: |
      - Em muốn xét bằng điểm thi THPT Quốc gia
      - Xét điểm tốt nghiệp THPT theo tổ hợp môn
      - /chon_ptxt_thptqg
      - chon_ptxt_thptqg
      - thi thpt quốc gia
      - điểm thi đại học

  - intent: inform
    examples: |
      - Nguyễn Trung Kiên
      - 0912345678
      - Số HSA của em là HSA-12345
      - Điểm thi là 95
      - Em được 6.5 ielts
      - Tổ hợp A00
      - Điểm thi là 27.5
      - https://cloudinary.com/xyz_evidence.png
      - Trần Văn B
      - 0987654321
      - HSA-99999
      - 105
      - 7.5 ielts
      - 8.5
      - Giải Nhất Tin học Quốc gia
      - A01
      - 28.25
      - https://drive.google.com/minhchung.png
      - Khoa học máy tính
      - Kỹ thuật phần mềm
      - Công nghệ thông tin
      - An toàn thông tin
